# ElderAI — environment variables
# Copy this file to .env and fill in your values.
# .env is in .gitignore and must never be committed.

# Gemini API key from https://aistudio.google.com/
GEMINI_API_KEY=INSERT_YOUR_KEY_HERE

# Optional: SHA-256 hash of your PIN (default below = "1234")
# Generate: python -c "import hashlib; print(hashlib.sha256(b'YOUR_PIN').hexdigest())"
AUTH_PIN_HASH=03ac674216f3e15c761ee1a5e255f067953623c8b388b4459e13f978d7c846f4

# Optional: TTS language code ("en" or "id" for Bahasa Indonesia)
TTS_LANG=en
